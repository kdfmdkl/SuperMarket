  "description": "Product created by manager",
  "sellPrice": 35000,
  "costPrice": 25000,
  "unit": "thùng",
  "barcode": "MANAGER_TEST_001",
  "minQuantity": 5,
  "maxQuantity": 100
}

### 4.3 Delete Product (Manager)
DELETE {{baseUrl}}/api/products/3
Authorization: Bearer {{managerToken}}

### ============================================
### 📦 5. CRUD PRODUCTS - WAREHOUSE
### ============================================

### 5.1 Get All Products (Warehouse)
GET {{baseUrl}}/api/products
Authorization: Bearer {{warehouseToken}}

### 5.2 Create Product (Warehouse) - SUCCESS
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{warehouseToken}}

{
  "name": "Warehouse Product Test",
  "description": "Product created by warehouse",
  "sellPrice": 15000,
  "costPrice": 10000,
  "unit": "chai",
  "barcode": "WAREHOUSE_TEST_001",
  "minQuantity": 20,
  "maxQuantity": 500
}

### 5.3 Delete Product (Warehouse) - FORBIDDEN (403)
DELETE {{baseUrl}}/api/products/1
Authorization: Bearer {{warehouseToken}}

### ============================================
### 📦 6. PRODUCTS - CASHIER (Chỉ được XEM)
### ============================================

### 6.1 Get All Products (Cashier) - SUCCESS
GET {{baseUrl}}/api/products
Authorization: Bearer {{cashierToken}}

### 6.2 Get Product By ID (Cashier) - SUCCESS
GET {{baseUrl}}/api/products/1
Authorization: Bearer {{cashierToken}}

### 6.3 Create Product (Cashier) - FORBIDDEN (403)
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{cashierToken}}

{
  "name": "Cashier Product Test",
  "sellPrice": 10000,
  "costPrice": 5000,
  "unit": "cái"
}

### 6.4 Update Product (Cashier) - FORBIDDEN (403)
PUT {{baseUrl}}/api/products/1
Content-Type: application/json
Authorization: Bearer {{cashierToken}}

{
  "name": "Updated by Cashier",
  "sellPrice": 20000
}

### 6.5 Delete Product (Cashier) - FORBIDDEN (403)
DELETE {{baseUrl}}/api/products/1
Authorization: Bearer {{cashierToken}}

### ============================================
### ❌ 7. VALIDATION TESTS
### ============================================

### 7.1 Missing Required Fields - 400 Bad Request
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "description": "Missing name and prices"
}

### 7.2 SellPrice < CostPrice - 400 Bad Request
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Invalid Price Product",
  "sellPrice": 5000,
  "costPrice": 10000,
  "unit": "pcs"
}

### 7.3 Duplicate Barcode - 400 Bad Request
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Duplicate Barcode Product",
  "sellPrice": 20000,
  "costPrice": 15000,
  "unit": "pcs",
  "barcode": "ADMIN_TEST_001"
}

### 7.4 Invalid CategoryId - 400 Bad Request
POST {{baseUrl}}/api/products
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Invalid Category Product",
  "sellPrice": 20000,
  "costPrice": 15000,
  "unit": "pcs",
  "categoryId": 99999
}

### 7.5 Product Not Found - 404 Not Found
GET {{baseUrl}}/api/products/99999
Authorization: Bearer {{adminToken}}

### ============================================
### 🔍 8. SEARCH & FILTER
### ============================================

### 8.1 Search Products by Keyword
GET {{baseUrl}}/api/products/search?keyword=Coca
Authorization: Bearer {{adminToken}}

### 8.2 Search Products by Barcode
GET {{baseUrl}}/api/products/search?keyword=ADMIN
Authorization: Bearer {{adminToken}}

### 8.3 Get Low Stock Products (threshold = 20)
GET {{baseUrl}}/api/products/low-stock?threshold=20
Authorization: Bearer {{adminToken}}

### 8.4 Get Low Stock Products (threshold = 50)
GET {{baseUrl}}/api/products/low-stock?threshold=50
Authorization: Bearer {{managerToken}}

### ============================================
### 🚫 9. NO TOKEN TESTS
### ============================================

### 9.1 Get Products without Token - 401 Unauthorized
GET {{baseUrl}}/api/products

### 9.2 Create Product without Token - 401 Unauthorized
POST {{baseUrl}}/api/products
Content-Type: application/json

{
  "name": "No Token Product",
  "sellPrice": 10000,
  "costPrice": 5000,
  "unit": "pcs"
}

### 9.3 Delete Product without Token - 401 Unauthorized
DELETE {{baseUrl}}/api/products/1

